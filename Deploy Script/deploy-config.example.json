{
  "// INSTRUCTIONS": "Copy this file to your app's project directory as deploy-config.json and fill in your values. The 'snowConnection' is the name of your connection in ~/.snowflake/connections.toml. For multi-app deployments, each app gets its own config with a unique service name, database name, image name, and file stage.",

  "snowConnection": "<your-snow-cli-connection-name>",

  "service": {
    "name": "<DATABASE>.<SCHEMA>.<YOUR_APP>_SERVICE",
    "computePool": "<YOUR_COMPUTE_POOL>",
    "imageRepo": "<database>/<schema>/<image_repo>",
    "imageName": "mendix-<your-app>",
    "externalAccessIntegration": "<YOUR_PG_EAI>"
  },

  "database": {
    "host": "<your-pg-host>.postgres.snowflake.app",
    "port": 5432,
    "name": "<your-app-db-name>",
    "username": "application",
    "password": "<your-pg-application-password>",
    "useSsl": true
  },

  "mendix": {
    "adminPassword": "<your-mendix-admin-password>",
    "fileStorageStage": "@<DATABASE>.<SCHEMA>.<YOUR_APP>_FILESTORAGE_STAGE"
  },

  "resources": {
    "memory": { "request": "1G", "limit": "2G" },
    "cpu": { "request": 0.5, "limit": 1 }
  }
}
